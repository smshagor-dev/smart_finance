{
  "name": "finance-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && next build",
    "start": "next start -p 3001",
    "postinstall": "prisma generate || true",
    "lint": "eslint",
    "db:check": "node prisma/setup-legacy-mysql.js --check",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:legacy-setup": "prisma generate && node prisma/setup-legacy-mysql.js",
    "db:seed": "node prisma/seed.js",
    "db:setup": "prisma generate && node prisma/setup-legacy-mysql.js && node prisma/seed.js",
    "start:prod": "prisma generate && node server.js"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.0",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "csv-stringify": "^6.7.0",
    "date-fns": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "prisma": "^6.19.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "xlsx": "^0.18.5",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4"
  }
}
