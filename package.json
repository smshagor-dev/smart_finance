{
  "name": "finance-tracker",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "vercel-build": "npm run build",
    "start": "npm run start:frontend",
    "start:frontend": "npm --prefix frontend run start",
    "start:backend": "npm --prefix backend run start",
    "check:env": "npm --prefix backend run check:env && npm --prefix frontend run check:env",
    "release": "npm --prefix backend run release",
    "docker:prod": "docker compose -f docker-compose.production.yml up --build -d",
    "postinstall": "node backend/scripts/run-prisma.cjs generate",
    "lint": "npm --prefix frontend run lint",
    "db:check": "npm --prefix backend run db:check",
    "db:generate": "npm --prefix backend run db:generate",
    "db:migrate": "npm --prefix backend run db:migrate",
    "db:migrate:dev": "npm --prefix backend run db:migrate:dev",
    "db:push": "npm --prefix backend run db:push",
    "db:legacy-setup": "npm --prefix backend run db:legacy-setup",
    "db:seed": "npm --prefix backend run db:seed",
    "db:setup": "npm --prefix backend run db:setup"
  }
}
