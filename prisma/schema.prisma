generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum CategoryType {
  income
  expense
}

enum TransactionType {
  income
  expense
  transfer
}

enum BudgetStatus {
  active
  exceeded
  completed
}

enum GoalStatus {
  active
  completed
  paused
}

enum RecurringFrequency {
  daily
  weekly
  monthly
  yearly
}

enum RecurringStatus {
  active
  paused
  completed
}

enum DebtType {
  borrowed
  lent
}

enum PaymentStatus {
  unpaid
  partial
  paid
}

enum NotificationType {
  budget
  bill
  balance
  savings
  insight
  system
}

enum InsightSeverity {
  info
  warning
  danger
  success
}

enum GroupRole {
  owner
  admin
  member
  viewer
}

enum MembershipStatus {
  invited
  active
  suspended
}

model User {
  id                   String                @id @default(cuid())
  name                 String?
  email                String?               @unique
  password             String?
  image                String?
  role                 UserRole              @default(user)
  emailVerified        DateTime?             @map("email_verified_at")
  defaultCurrencyId    String?
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  defaultCurrency      Currency?             @relation("UserDefaultCurrency", fields: [defaultCurrencyId], references: [id], onDelete: SetNull)
  accounts             Account[]
  sessions             Session[]
  wallets              Wallet[]
  categories           Category[]
  transactions         Transaction[]
  budgets              Budget[]
  savingsGoals         SavingsGoal[]
  savingsContributions SavingsContribution[]
  recurringPayments    RecurringPayment[]
  debtLoans            DebtLoan[]
  debtPayments         DebtPayment[]
  notifications        Notification[]
  settings             UserSetting?
  aiInsights           AIInsight[]
  receipts             Receipt[]
  exportLogs           ExportLog[]
  groupMemberships     FinanceGroupMember[]
  financeGroups        FinanceGroup[]        @relation("FinanceGroupOwner")
  groupInvites         FinanceGroupInvite[]
  groupMessages        GroupMessage[]

  @@index([defaultCurrencyId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  oauth_token_secret String? @db.Text
  oauth_token       String? @db.Text
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Wallet {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  name              String
  type              String
  balance           Decimal       @db.Decimal(14, 2)
  currencyId        String?       @map("currency_id")
  icon              String?
  color             String?
  isDefault         Boolean       @default(false) @map("is_default")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency          Currency?     @relation(fields: [currencyId], references: [id], onDelete: SetNull)
  transactions      Transaction[]
  budgets           Budget[]
  recurringPayments RecurringPayment[]

  @@index([userId])
  @@index([currencyId])
}

model Category {
  id                String             @id @default(cuid())
  userId            String?            @map("user_id")
  name              String
  type              CategoryType
  icon              String?
  color             String?
  isDefault         Boolean            @default(false) @map("is_default")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  budgets           Budget[]
  recurringPayments RecurringPayment[]

  @@index([userId, type])
}

model Transaction {
  id              String          @id @default(cuid())
  userId          String          @map("user_id")
  groupId         String?         @map("group_id")
  type            TransactionType
  amount          Decimal         @db.Decimal(14, 2)
  originalAmount  Decimal         @db.Decimal(14, 2) @map("original_amount")
  convertedAmount Decimal         @db.Decimal(14, 2) @map("converted_amount")
  categoryId      String?         @map("category_id")
  walletId        String          @map("wallet_id")
  note            String?         @db.Text
  transactionDate DateTime        @map("transaction_date")
  paymentMethod   String?         @map("payment_method")
  attachmentUrl   String?         @map("attachment_url")
  currencyId      String?         @map("currency_id")
  exchangeRate    Decimal?        @db.Decimal(14, 6) @map("exchange_rate")
  incomeSource    String?         @map("income_source")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet          Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  category        Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  currency        Currency?       @relation(fields: [currencyId], references: [id], onDelete: SetNull)
  receipts        Receipt[]
  group           FinanceGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([userId, type, transactionDate])
  @@index([currencyId])
  @@index([walletId])
}

model Budget {
  id         String       @id @default(cuid())
  userId     String       @map("user_id")
  categoryId String?      @map("category_id")
  walletId   String?      @map("wallet_id")
  amount     Decimal      @db.Decimal(14, 2)
  month      Int
  year       Int
  startDate  DateTime     @map("start_date")
  endDate    DateTime     @map("end_date")
  status     BudgetStatus @default(active)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  wallet     Wallet?      @relation(fields: [walletId], references: [id], onDelete: SetNull)

  @@index([userId, month, year])
}

model SavingsGoal {
  id            String                @id @default(cuid())
  userId        String                @map("user_id")
  title         String
  targetAmount  Decimal               @db.Decimal(14, 2) @map("target_amount")
  currentAmount Decimal               @default(0) @db.Decimal(14, 2) @map("current_amount")
  deadline      DateTime?
  status        GoalStatus            @default(active)
  icon          String?
  color         String?
  note          String?               @db.Text
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions SavingsContribution[]

  @@index([userId, status])
}

model SavingsContribution {
  id               String      @id @default(cuid())
  userId           String      @map("user_id")
  savingsGoalId    String      @map("savings_goal_id")
  amount           Decimal     @db.Decimal(14, 2)
  note             String?
  contributionDate DateTime    @default(now()) @map("contribution_date")
  createdAt        DateTime    @default(now()) @map("created_at")
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsGoal      SavingsGoal @relation(fields: [savingsGoalId], references: [id], onDelete: Cascade)

  @@index([userId, savingsGoalId])
}

model RecurringPayment {
  id          String             @id @default(cuid())
  userId      String             @map("user_id")
  title       String
  type        TransactionType
  amount      Decimal            @db.Decimal(14, 2)
  categoryId  String?            @map("category_id")
  walletId    String?            @map("wallet_id")
  frequency   RecurringFrequency
  startDate   DateTime           @map("start_date")
  endDate     DateTime?          @map("end_date")
  nextDueDate DateTime           @map("next_due_date")
  autoCreate  Boolean            @default(false) @map("auto_create")
  status      RecurringStatus    @default(active)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  wallet      Wallet?            @relation(fields: [walletId], references: [id], onDelete: SetNull)

  @@index([userId, nextDueDate])
}

model DebtLoan {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  personName String        @map("person_name")
  type       DebtType
  amount     Decimal       @db.Decimal(14, 2)
  paidAmount Decimal       @default(0) @db.Decimal(14, 2) @map("paid_amount")
  dueDate    DateTime?     @map("due_date")
  status     PaymentStatus @default(unpaid)
  note       String?       @db.Text
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments   DebtPayment[]

  @@index([userId, status])
}

model DebtPayment {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  debtLoanId  String   @map("debt_loan_id")
  amount      Decimal  @db.Decimal(14, 2)
  note        String?
  paymentDate DateTime @default(now()) @map("payment_date")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  debtLoan    DebtLoan @relation(fields: [debtLoanId], references: [id], onDelete: Cascade)

  @@index([userId, debtLoanId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  title     String
  message   String           @db.Text
  type      NotificationType
  isRead    Boolean          @default(false) @map("is_read")
  actionUrl String?          @map("action_url")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model UserSetting {
  id                 String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  language           String   @default("en")
  theme              String   @default("light")
  timezone           String   @default("UTC")
  emailNotifications Boolean  @default(true) @map("email_notifications")
  budgetAlerts       Boolean  @default(true) @map("budget_alerts")
  billReminders      Boolean  @default(true) @map("bill_reminders")
  lowBalanceWarnings Boolean  @default(true) @map("low_balance_warnings")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AIInsight {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  insightType String          @map("insight_type")
  title       String
  description String          @db.Text
  severity    InsightSeverity @default(info)
  generatedAt DateTime        @default(now()) @map("generated_at")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, generatedAt])
}

model Receipt {
  id           String       @id @default(cuid())
  userId       String       @map("user_id")
  transactionId String?     @map("transaction_id")
  fileUrl      String       @map("file_url")
  fileType     String       @map("file_type")
  originalName String       @map("original_name")
  uploadedAt   DateTime     @default(now()) @map("uploaded_at")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction  Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([userId, transactionId])
}

model Currency {
  id                String        @id @default(cuid())
  code              String        @unique
  name              String?
  symbol            String?
  exchangeRateToUsd Decimal       @default(1) @db.Decimal(14, 6) @map("exchange_rate_to_usd")
  isActive          Boolean       @default(true) @map("is_active")
  lastSyncedAt      DateTime?     @map("last_synced_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  defaultUsers      User[]        @relation("UserDefaultCurrency")
  wallets           Wallet[]
  transactions      Transaction[]

  @@map("currencies")
}

model FinanceGroup {
  id           String               @id @default(cuid())
  ownerId      String               @map("owner_id")
  name         String
  description  String?              @db.Text
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  owner        User                 @relation("FinanceGroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      FinanceGroupMember[]
  invites      FinanceGroupInvite[]
  messages     GroupMessage[]
  transactions Transaction[]

  @@index([ownerId])
}

model FinanceGroupMember {
  id        String           @id @default(cuid())
  groupId   String           @map("group_id")
  userId    String           @map("user_id")
  role      GroupRole        @default(member)
  status    MembershipStatus @default(active)
  createdAt DateTime         @default(now()) @map("created_at")
  group     FinanceGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model FinanceGroupInvite {
  id         String       @id @default(cuid())
  groupId     String      @map("group_id")
  token      String       @unique
  createdById String      @map("created_by_id")
  expiresAt  DateTime     @map("expires_at")
  maxUses    Int          @default(25) @map("max_uses")
  usesCount  Int          @default(0) @map("uses_count")
  isActive   Boolean      @default(true) @map("is_active")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  group      FinanceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy  User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([groupId, isActive])
  @@index([createdById])
}

model GroupMessage {
  id        String       @id @default(cuid())
  groupId   String       @map("group_id")
  userId    String       @map("user_id")
  body      String       @db.Text
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  group     FinanceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
  @@index([userId])
}

model ExportLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  format    String
  resource  String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, format])
}

model SiteSetting {
  id                            String   @id @default("global")
  siteName                      String   @default("Finance Tracker") @map("site_name")
  siteTagline                   String?  @map("site_tagline")
  siteDescription               String   @default("Personal finance tracker built with Next.js, Prisma, and MySQL") @db.Text @map("site_description")
  seoTitle                      String?  @map("seo_title")
  seoDescription                String?  @db.Text @map("seo_description")
  seoKeywords                   String?  @db.Text @map("seo_keywords")
  logoUrl                       String?  @map("logo_url")
  iconUrl                       String?  @map("icon_url")
  supportEmail                  String?  @map("support_email")
  siteUrl                       String?  @map("site_url")
  smtpHost                      String?  @map("smtp_host")
  smtpPort                      Int      @default(587) @map("smtp_port")
  smtpSecure                    Boolean  @default(false) @map("smtp_secure")
  smtpUser                      String?  @map("smtp_user")
  smtpPass                      String?  @db.Text @map("smtp_pass")
  smtpFrom                      String?  @map("smtp_from")
  requireEmailVerification      Boolean  @default(true) @map("require_email_verification")
  verificationCodeExpiryMinutes Int      @default(15) @map("verification_code_expiry_minutes")
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
